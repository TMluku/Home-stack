{
  "name": "home-stack",
  "version": "0.1.0",
  "private": true,
  "description": "Mobile web MVP for home consumables replenishment.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pages": "node scripts/build-pages.mjs",
    "check:pages": "node scripts/check-pages-readiness.mjs",
    "deploy:pages-branch": "node scripts/publish-pages-branch.mjs",
    "preview:pages": "node scripts/serve-pages.mjs",
    "test:e2e": "node scripts/e2e-pages-smoke.mjs",
    "test:e2e:browser": "playwright test",
    "check:mobile-qa-evidence": "node scripts/check-mobile-qa-evidence.mjs",
    "check:real-device-qa": "node scripts/check-real-device-qa.mjs",
    "start": "next start",
    "check": "tsc --noEmit && biome check . && vitest run",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "ci": "turbo run typecheck lint build",
    "clean:generated": "node scripts/clean-generated.mjs",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepare": "lefthook install",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "next": "^15.3.4",
    "nodemailer": "7.0.10",
    "postgres": "3.4.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "web-push": "3.6.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "7.0.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/web-push": "3.6.4",
    "lefthook": "^1.13.6",
    "turbo": "^2.5.6",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "type": "module",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  }
}
