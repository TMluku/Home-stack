{
  "name": "home-stack",
  "version": "0.1.0",
  "private": true,
  "description": "Mobile web MVP for home consumables replenishment.",
  "scripts": {
    "start": "node server/api-server.mjs",
    "check": "pnpm run check:static && pnpm test",
    "test": "node --test tests/*.test.mjs",
    "start:static": "python3 -m http.server 4173",
    "api": "node server/api-server.mjs",
    "check:static": "node scripts/check-static-app.mjs",
    "ci": "turbo run check:static test lint",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepare": "lefthook install",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "lefthook": "^1.13.6",
    "turbo": "^2.5.6"
  },
  "type": "module",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  }
}
